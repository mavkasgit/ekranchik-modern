# Режим работы браузера: 'cdp' | 'headless' | 'headed'
E2E_BROWSER_MODE=cdp

# Путь к исполняемому файлу Chrome (для автоматического запуска)
CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"

# Порт отладки для CDP
BROWSER_PORT=9222
REMOTE_CHROME_HOST=127.0.0.1

# URL фронтенда и бэкенда
E2E_BASE_URL=http://127.0.0.1:5173
E2E_API_URL=http://127.0.0.1:8000/api
