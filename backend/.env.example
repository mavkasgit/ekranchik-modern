# Ekranchik Modern - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================================================
# ОСНОВНЫЕ НАСТРОЙКИ
# ============================================================================

# Application
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (stored in static folder)
DATABASE_URL=sqlite+aiosqlite:///../static/ekranchik.db

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Static files
STATIC_DIR=../static
IMAGES_DIR=../static/images

# Photo upload
MAX_UPLOAD_SIZE=10485760


# ============================================================================
# ПЕРЕКЛЮЧАТЕЛЬ РЕЖИМА РАБОТЫ
# ============================================================================
# Используйте кнопку в лаунчере для переключения между режимами
# false = РАБОЧИЙ режим (реальные данные)
# true  = ТЕСТОВЫЙ режим (локальные данные)
SIMULATION_ENABLED=false


# ============================================================================
# РАБОЧИЙ РЕЖИМ - Реальные данные производства
# ============================================================================

# OPC UA - Реальный сервер
OPCUA_ENABLED=true
OPCUA_ENDPOINT=opc.tcp://172.17.11.115:4840/
OPCUA_POLL_INTERVAL=1.0

# Excel - Начальный путь к сетевому файлу (используется при первом запуске в рабочем режиме,
# если не был сохранен выбор пользователя в static/active_excel.json)
EXCEL_REAL_FILE_PATH=\\ktm-disk\\Оператор\\Учет КПЗ 2026.xlsm


# ============================================================================
# ТЕСТОВЫЙ РЕЖИМ - Локальные данные для разработки
# ============================================================================

# OPC UA - Локальный симулятор
OPCUA_SIM_ENDPOINT=opc.tcp://127.0.0.1:4840/freeopcua/server/
OPCUA_SIM_POLL_INTERVAL=1.0

# Excel - Начальный путь к локальному тестовому файлу (используется при первом запуске в тест-режиме,
# если не был сохранен выбор пользователя в static/active_excel_sim.json)
EXCEL_TEST_FILE_PATH=../testdata/Учет КПЗ 2026.xlsm

# KTM-2000 Integration Settings
KTM_BACKEND_URL=http://host.docker.internal:8082

