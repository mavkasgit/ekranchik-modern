{
  "name": "ekranchik-modern",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install && npm install --prefix frontend",
    "dev": "concurrently --names \"BACKEND,FRONTEND,SIMULATOR\" -c \"green,cyan,blue\" \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:simulator\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "dev:simulator": "cd backend && python opcua_server_simulator.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "shell-quote": "^1.8.4"
  }
}
